# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=screenhub
DB_USER=screenhub_user
DB_PASSWORD=your_password_here

# ── Authentication ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# ── Google Cloud Storage (optional) ────────────────────────────
GCS_BUCKET_NAME=screenhub-media
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── MercadoPago (configured via Superadmin panel) ───────────────
# MP credentials are stored in the database and managed through
# the Superadmin panel at /superadmin → Configuración

# ── Default superadmin credentials (CHANGE IMMEDIATELY) ─────────
# Email: superadmin@screenhub.com
# Password: screenhub2026
# Run migration 002_saas_schema.sql to create the superadmin user
